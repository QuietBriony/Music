{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://quietbriony.github.io/Music/docs/schema/music-session-packet.schema.json",
  "title": "Music Session Packet",
  "description": "Metadata-only conductor packet emitted by Music for orchestra routing.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "source_repo",
    "created_at",
    "session_id",
    "mode",
    "reference_gradient",
    "ucm_state",
    "output_state",
    "performance_state",
    "music_intent",
    "routing",
    "safety"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "source_repo": {
      "const": "Music"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "ambient",
        "idm",
        "techno",
        "reference_gradient",
        "self_running"
      ]
    },
    "reference_gradient": {
      "type": "object",
      "additionalProperties": false,
      "required": ["weights"],
      "properties": {
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "required": ["haze", "memory", "micro", "ghost", "chrome", "organic"],
          "properties": {
            "haze": { "$ref": "#/definitions/unitInterval" },
            "memory": { "$ref": "#/definitions/unitInterval" },
            "micro": { "$ref": "#/definitions/unitInterval" },
            "ghost": { "$ref": "#/definitions/unitInterval" },
            "chrome": { "$ref": "#/definitions/unitInterval" },
            "organic": { "$ref": "#/definitions/unitInterval" }
          }
        }
      }
    },
    "ucm_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "energy",
        "wave",
        "mind",
        "creation",
        "void",
        "circle",
        "body",
        "resource",
        "observer"
      ],
      "properties": {
        "energy": { "$ref": "#/definitions/percent100" },
        "wave": { "$ref": "#/definitions/percent100" },
        "mind": { "$ref": "#/definitions/percent100" },
        "creation": { "$ref": "#/definitions/percent100" },
        "void": { "$ref": "#/definitions/percent100" },
        "circle": { "$ref": "#/definitions/percent100" },
        "body": { "$ref": "#/definitions/percent100" },
        "resource": { "$ref": "#/definitions/percent100" },
        "observer": { "$ref": "#/definitions/percent100" }
      }
    },
    "output_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["output_level", "recorder_duration"],
      "properties": {
        "output_level": { "$ref": "#/definitions/percent100" },
        "recorder_duration": {
          "type": "number",
          "minimum": 0
        },
        "review_boost": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        }
      }
    },
    "performance_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_pad",
        "recent_pads",
        "manual_influence_active",
        "automix_enabled"
      ],
      "properties": {
        "active_pad": {
          "type": ["string", "null"]
        },
        "recent_pads": {
          "type": "array",
          "items": { "type": "string" }
        },
        "manual_influence_active": {
          "type": "boolean"
        },
        "automix_enabled": {
          "type": "boolean"
        },
        "mic_follow": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "status": { "type": "string" },
            "input_level": { "$ref": "#/definitions/unitInterval" },
            "onset_rate": { "$ref": "#/definitions/unitInterval" },
            "rough_tempo": {
              "type": "number",
              "minimum": 0,
              "maximum": 240
            },
            "density": { "$ref": "#/definitions/unitInterval" },
            "stability": { "$ref": "#/definitions/unitInterval" },
            "silence": { "$ref": "#/definitions/unitInterval" },
            "brightness": { "$ref": "#/definitions/unitInterval" },
            "metadata_only": { "const": true },
            "stores_audio": { "const": false }
          }
        }
      }
    },
    "music_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timbre", "rhythm", "space", "structure", "gesture", "safety"],
      "properties": {
        "timbre": { "$ref": "#/definitions/intentValue" },
        "rhythm": { "$ref": "#/definitions/intentValue" },
        "space": { "$ref": "#/definitions/intentValue" },
        "structure": { "$ref": "#/definitions/intentValue" },
        "gesture": { "$ref": "#/definitions/intentValue" },
        "safety": { "$ref": "#/definitions/intentValue" }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["drum_floor", "namima", "chill", "openclaw"],
      "properties": {
        "drum_floor": {
          "type": "object",
          "additionalProperties": true,
          "required": ["enabled", "groove_intent", "density", "pressure", "section"],
          "properties": {
            "enabled": { "type": "boolean" },
            "groove_intent": { "$ref": "#/definitions/intentValue" },
            "density": { "$ref": "#/definitions/unitInterval" },
            "pressure": { "$ref": "#/definitions/unitInterval" },
            "section": { "type": "string" }
          }
        },
        "namima": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "enabled",
            "mood_intent",
            "family_safe",
            "water_motion",
            "brightness"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "mood_intent": { "$ref": "#/definitions/intentValue" },
            "family_safe": { "type": "boolean" },
            "water_motion": { "$ref": "#/definitions/unitInterval" },
            "brightness": { "$ref": "#/definitions/unitInterval" }
          }
        },
        "chill": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "enabled",
            "trio_intent",
            "piano_memory",
            "bass_activity",
            "drum_support",
            "section"
          ],
          "properties": {
            "enabled": { "type": "boolean" },
            "trio_intent": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "reference_id": { "type": "string" },
                "touch": { "$ref": "#/definitions/unitInterval" },
                "phrase": { "$ref": "#/definitions/unitInterval" },
                "room": { "$ref": "#/definitions/unitInterval" },
                "flow_on": { "type": "boolean" },
                "bass_on": { "type": "boolean" },
                "drums_suggested": { "type": "boolean" },
                "pressure_target": { "type": "string" },
                "review_only": { "type": "boolean" }
              }
            },
            "piano_memory": { "$ref": "#/definitions/unitInterval" },
            "bass_activity": { "$ref": "#/definitions/unitInterval" },
            "drum_support": { "$ref": "#/definitions/unitInterval" },
            "section": { "type": "string" }
          }
        },
        "openclaw": {
          "type": "object",
          "additionalProperties": true,
          "required": ["enabled", "promotion_status", "human_review_required"],
          "properties": {
            "enabled": { "type": "boolean" },
            "promotion_status": {
              "type": "string",
              "examples": ["draft", "review", "approved", "rejected"]
            },
            "human_review_required": {
              "const": true
            },
            "next_action": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "destination": {
                  "type": "string",
                  "examples": ["music", "chill", "drum_floor", "namima", "openclaw"]
                },
                "label": { "type": "string" },
                "reason": { "type": "string" },
                "action": { "type": "string" },
                "confidence": { "$ref": "#/definitions/unitInterval" },
                "manual_start_required": { "type": "boolean" },
                "metadata_only": { "type": "boolean" }
              }
            },
            "self_review": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "densityRisk": { "$ref": "#/definitions/unitInterval" },
                "lowEndRisk": { "$ref": "#/definitions/unitInterval" },
                "brightnessRisk": { "$ref": "#/definitions/unitInterval" },
                "restraintScore": { "$ref": "#/definitions/unitInterval" },
                "referenceFit": { "$ref": "#/definitions/unitInterval" },
                "nextSuggestion": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stores_audio",
        "stores_samples",
        "stores_lyrics",
        "metadata_only",
        "human_review_required"
      ],
      "properties": {
        "stores_audio": { "const": false },
        "stores_samples": { "const": false },
        "stores_lyrics": { "const": false },
        "metadata_only": { "const": true },
        "human_review_required": { "const": true }
      }
    }
  },
  "definitions": {
    "unitInterval": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "percent100": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "intentValue": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      ]
    }
  }
}
