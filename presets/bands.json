  "add_new_band_workflow": {
    "step_1": "Desktop/musicpl/{band-name}/ に m4a / wav 音源を配置",
    "step_2": "scripts/_separate_band.py {band-id} を実行 (Demucs で 4-stem 分離)",
    "step_3": "presets/drum-frames-{bandid}-{songid}.json を手書き or generator で作成",
    "step_4": "presets/bands.json の bands.{bandid}.songs に entry 追加",
    "step_5": "sw.js precache に該当 stems 追加 (オプション、large band は on-demand)",
    "step_6": "band-room.html 再読込で band selector に新 band が出現"
  },
