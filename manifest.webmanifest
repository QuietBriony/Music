{
  "name": "Hazama FM",
  "short_name": "Hazama FM",
  "description": "Generative focus radio — music for thinking and building.",
  "start_url": "fm.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "orientation": "any",
  "background_color": "#040e18",
  "theme_color": "#040e18",
  "lang": "ja",
  "categories": ["music", "entertainment", "productivity"],
